{
  "name": "4_webdriverIO",
  "type": "module",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.27.2",
    "@wdio/cli": "^9.27.2",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "allure-commandline": "^2.42.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2"
  },
  "scripts": {
    "test": "wdio run ./wdio.conf.js",
    "test:prod": "cross-env NODE_ENV=prod BASE_URL=https://telnyx.com wdio run ./wdio.conf.js",
    "test:local": "cross-env NODE_ENV=local BASE_URL=https://telnyx.com wdio run ./wdio.conf.js",
    "test:chrome": "wdio run ./config/wdio.chrome.conf.js",
    "test:firefox": "wdio run ./config/wdio.firefox.conf.js",
    "allure:generate": "allure generate allure-results --clean",
    "allure:open": "allure open",
    "allure:report": "allure generate allure-results --clean && allure open"
  }
}